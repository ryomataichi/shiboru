<div class="account-edit-page">
  <div class="account-edit-card">
    <h3>プロフィールを編集する</h3>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "account-edit-form" }) do |f| %>
      <%= render "users/shared/error_messages", resource: resource %>

      <div class="form_row">
        <%= f.label :name, "ユーザーネーム", class: "form_label" %>
        <%= f.text_field :name, autofocus: true, autocomplete: "name", class: "form_input" %>
      </div>

      <div class="form_row">
        <%= f.label :profile, "自己紹介", class: "form_label" %>
        <%= f.text_area :profile, rows: 6, class: "form_textarea" %>
      </div>

      <div class="form_row">
        <%= f.label :image, "プロフィール画像", class: "form_label" %>
        <%= f.file_field :image, class: "form_file" %>
      </div>

      <div class="form_row">
        <%= f.label :email, "メールアドレス", class: "form_label" %>
        <%= f.email_field :email, autocomplete: "email", class: "form_input" %>
      </div>

      <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
        <div class="form_notice">
          Currently waiting confirmation for: <%= resource.unconfirmed_email %>
        </div>
      <% end %>

      <div class="form_row">
        <%= f.label :password, "新しいパスワード", class: "form_label" %>
        <%= f.password_field :password, autocomplete: "new-password", class: "form_input" %>
        <% if @minimum_password_length %>
          <p class="form_hint">※<%= @minimum_password_length %>文字以上の英数字で入力してください。</p>
        <% end %>
      </div>

      <div class="form_row">
        <%= f.label :password_confirmation, "新しいパスワードをもう一度入力してください", class: "form_label" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form_input" %>
      </div>

      <div class="form_row">
        <%= f.label :current_password, "現在のパスワードを入力してから更新ボタンを押してください！", class: "form_label" %>
        <%= f.password_field :current_password, autocomplete: "current-password", class: "form_input" %>
      </div>

      <div class="form_actions">
        <%= f.submit "更新", class: "submit_button" %>
      </div>
    <% end %>

    <div class="account_links">
      <%= link_to "戻る", user_path(@user.id), class: "back_link" %>
    </div>

    <div class="danger_zone">
      <%= button_to "アカウントを削除する",
            registration_path(resource_name),
            data: { confirm: "Are you sure?", turbo_confirm: "Are you sure?" },
            class: "delete_image_button",
            method: :delete %>
    </div>
  </div>
</div>



