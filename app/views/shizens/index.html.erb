<div class="main">
<h3>Shiboruへようこそ
<br>
本サイトは綺麗な自然スポットを保存、共有するための投稿サイトです。</h3></div>
<br><br>
    <div class="search-wrapper">
        <%= link_to '新しい順', shizens_path(new:"new")%> | 
        <%= link_to '古い順', shizens_path(old:"old")%> | 
        <%= link_to '評価の高い順', shizens_path(good:"good")%>

        <span id="search-icon"><i class="fa-solid fa-magnifying-glass"></i></span>
        <div id="search-form" class="hidden">
            <%= form_tag({controller:"shizens",action:"index"}, method: :get) do %>
                <%= text_field_tag :search %>
                <%= submit_tag '検索する'  %>
            <% end %>
        </div>
    </div>
    <div class="shizens-container">
        <% @shizens.each do |t| %>
            <div class="shizen">
                <div class="shizen-content">
                    <div class="shizen-text">
                        <%= link_to smart_truncate(t.spot_name, 6), shizen_path(t.id) ,class: "spot-name" %>
                            <div class=" oya-hourly-weather">
                                <div class="hourly-weather">
                                    <% if t.hourly_weather_type.present? %>
                                        <% if t.hourly_weather_at.present? %>
                                            <%= t.hourly_weather_at.in_time_zone.strftime("%H:00") %>~<%= (t.hourly_weather_at + 1.hour).in_time_zone.strftime("%H:00") %>の天気
                                        <% end %>
                                        <%= image_tag weather_image_name(t.hourly_weather_type), size: "40x40", alt: weather_label(t.hourly_weather_type) %>
                                    <% else %>
                                        1時間ごとの天気情報を取得できませんでした
                                    <% end %>
                                </div>
                            </div>
                        <span class="like-count">
                            <% if user_signed_in? %>
                                <% if current_user.already_liked?(t) %>
                                    <%= link_to shizen_like_path(id: t.id, shizen_id: t.id), method: :delete do %>
                                        <i class="fas fa-heart"></i><%= t.likes.count %>    
                                    <% end %>
                                <% else %>
                                    <%= link_to shizen_likes_path(id: t.id, shizen_id: t.id), method: :post do %>
                                        <i class="fa-regular fa-heart"></i><%= t.likes.count %>
                                    <% end %>
                                <% end %>
                            <% else %>
                                <i class="fa-regular fa-heart"></i><%= t.likes.count %>
                            <% end %>
                        </span>
                        <span class="map-link">
                            <% if t.maplink? %>
                                <%= link_to t.maplink do %>
                                    <i class="fa-solid fa-location-dot fa-2xl"></i>
                                <% end %>
                            <% else %>
                                <i class="fa-solid fa-location-dot fa-2xl" style="color: rgb(150, 149, 149);"></i>
                            <% end %>
                            <% if t.ken.present? %>
                                <%= link_to t.ken, shizen_matome_path(t.id), class: "ken-tag" %>
                            <% else %>
                                <span class= "ken-tag"> 未登録 </span>
                            <% end %>
                        </span>
                        <br>
                        <div class="user-info">
                            <%= link_to user_path(t.user.id) do %>
                                <% if t.user.image.attached? %>
                                    <%= image_tag t.user.image,style: "border-radius: 50%; width: 32px; height: 32px; object-fit:cover;" %>
                                <% else %>
                                    <br>
                                    <i class="fa-solid fa-user fa-2xl" style="color: rgb(150, 149, 149);"></i>
                                <% end %>
                                <%= t.user.name %>
                            <% end %>
                            <br>
                            <%= smart_truncate(t.setumei, 17) %>
                        </div>
                    </div>
                        <%= link_to shizen_path(t.id) do %> 
                            <% if t.images.attached? %>
                                <div class="shizen-image"><%= image_tag t.images.first,style: "border-radius: 20px; width: 360px; height: 240px; object-fit:cover;" %></div> 
                            <% end %>
                        <% end %>
                </div>
            </div>
        <% end %>
    </div>
    <br><br><h1>今すぐ行ける！直近1時間の晴れスポット一覧</h1><br><br>
    <div class="shizens-container">
        <% @sunny_shizens.each do |t| %>
            <div class="shizen">
                <div class="shizen-content">
                    <div class="shizen-text">
                    <%= link_to smart_truncate(t.spot_name, 6), shizen_path(t.id) ,class: "spot-name" %>
                        <div class=" oya-hourly-weather">
                            <div class="hourly-weather">
                                <% if t.hourly_weather_type.present? %>
                                    <% if t.hourly_weather_at.present? %>        
                                        <%= t.hourly_weather_at.in_time_zone.strftime("%H:00") %>~<%= (t.hourly_weather_at + 1.hour).in_time_zone.strftime("%H:00") %>の天気
                                    <% end %>
                                    <%= image_tag weather_image_name(t.hourly_weather_type), size: "40x40", alt: weather_label(t.hourly_weather_type) %>
                                <% else %>
                                    1時間ごとの天気情報を取得できませんでした
                                <% end %>
                            </div>
                        </div>
                        <span class="like-count">
                            <% if user_signed_in? %>
                                <% if current_user.already_liked?(t) %>
                                    <%= link_to shizen_like_path(id: t.id, shizen_id: t.id), method: :delete do %>
                                        <i class="fas fa-heart"></i><%= t.likes.count %>    
                                    <% end %>
                                <% else %>
                                    <%= link_to shizen_likes_path(id: t.id, shizen_id: t.id), method: :post do %>
                                        <i class="fa-regular fa-heart"></i><%= t.likes.count %>
                                    <% end %>
                                <% end %>
                            <% else %>
                                <i class="fa-regular fa-heart"></i><%= t.likes.count %>
                            <% end %>
                        </span>
                        <span class="map-link">
                            <%= link_to t.maplink do %>
                                <i class="fa-solid fa-location-dot fa-2xl"></i>
                            <% end %>
                            <%= link_to t.ken, shizen_matome_path(t.id), class: "ken-tag" %>
                        </span>
                    <br>
                        <%= link_to user_path(t.user.id) do %>
                            <% if t.user.image.attached? %>
                                <%= image_tag t.user.image,style: "border-radius: 50%; width: 36px; height: 36px; object-fit:cover;" %>
                            <% else %>
                                <i class="fa-solid fa-user" style="color: rgb(150, 149, 149);"></i>
                            <% end %>
                            <%= t.user.name %>                            
                        <% end %>
                    <br>
                    <%= smart_truncate(t.setumei, 17) %>
                    </div>
                    <%= link_to shizen_path(t.id) do %> 
                        <% if t.tategazou.attached? %>
                            <div class="shizen-image"><%= image_tag t.tategazou,style: "border-radius: 20px; width: 360px; height: 240px; object-fit:cover;" %></div> 
                        <% elsif t.yokogazou.attached? %>
                            <div class="shizen-image"><%= image_tag t.yokogazou,style: "border-radius: 20px; width: 360px; height: 240px; object-fit:cover;" %></div>
                        <% elsif t.tategazou2.attached? %>
                            <div class="shizen-image"><%= image_tag t.tategazou2,style: "border-radius: 20px; width: 360px; height: 240px; object-fit:cover;" %></div>
                        <% elsif t.yokogazou2.attached? %>
                            <div class="shizen-image"><%= image_tag t.yokogazou2,style: "border-radius: 20px; width: 360px; height: 240px; object-fit:cover;" %></div>
                        <% else %>
                            <div class="shizen-image"><%= image_tag "no_image.png",style: "border-radius: 20px; width: 360px; height: 240px; object-fit:cover;" %></div>
                        <% end %>
                    <% end %>
                </div>
            </div>
        <% end %>
    </div>   
</div>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">