<div class="edit_container">
  <div class="edit_card">
    <div class="edit_header">
      <h2>投稿編集</h2>
      <p>自然のきれいなスポットをシェアしよう</p>
    </div>
    <%= form_for @shizen do |f| %>
      <div class="form_grid">
        <div class="form_row">
          <%= f.label :spot_name, "場所名", class: "form_label" %>
          <%= f.text_field :spot_name, class: "form_input", placeholder: "例：白馬岩岳マウンテンリゾート" %>
        </div>

        <div class="form_row short">
          <%= f.label :ken, "都道府県", class: "form_label" %>
          <%= f.text_field :ken, class: "form_input", placeholder: "例：長野県" %>
        </div>

        <div class="form_row">
          <%= f.label :maplink, "Googleマップのリンク", class: "form_label" %>
          <%= f.url_field :maplink, class: "form_input", placeholder: "https://maps.app.goo.gl/..." %>
        </div>

        <div class="form_row full">
          <%= f.label :setumei, "説明文", class: "form_label" %>
          <%= f.text_area :setumei, class: "form_textarea", rows: 6, placeholder: "スポットの魅力やおすすめの時間帯を書いてください" %>
        </div>
      </div>
      <div class="form_row full">
        <%= f.label :images, "画像を追加", class: "form_label" %>
        <%= f.file_field :images, multiple: true, class: "form_file" %>
        <p class="form_hint">新しく選んだ画像だけ追加されます。何も選ばなければ既存画像はそのままです。</p>
      </div>

      <div class="form_actions">
        <%= link_to "投稿に戻る", shizen_path(@shizen.id), class: "back_link" %>
        <%= f.submit "編集する", class: "submit_button" %>
    <% end %>
        <% if user_signed_in? && current_user.id == @shizen.user_id %>
                <%= button_to "削除", shizen_path(@shizen.id), class: "delete_image_button", method: :delete %>
        <% end %>
        </div>
  </div>
  <div class="image_card">
    <div class="form_row full">
      <label class="form_label">現在の画像</label>
        <% if @shizen.images.attached? %>
          <div class="edit-image-container">
            <% @shizen.images.each do |image| %>
              <% orientation = image_orientation(image) %>
              <div class="image_item">
                <div class="photo <%= orientation %>">
                  <%= image_tag image %>
                </div>
                <%= button_to "画像削除",purge_image_shizen_path(@shizen, image_id: image.id),method: :delete,data: { turbo_confirm: "この画像を削除しますか？" },class: "delete_image_button" %>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="form_hint">まだ画像は登録されていません</p>
        <% end %>
    </div>
  </div>
</div>